#!/usr/bin/env bash
# Finds broken relative markdown links inside wiki/ (and optionally docs/).
# Lists hits as file:line:link. Exit code 1 if hits found, 0 if clean.
#
# Skips:
#  - Links inside fenced code blocks (``` ... ```)
#  - External URLs (http://, https://, mailto:, tel:, ftp:)
#  - Fragment-only links (#section)
#
# Usage: wiki-broken-links [--include-docs]
set -euo pipefail

include_docs=0
case "${1:-}" in
  --include-docs) include_docs=1 ;;
  -h|--help)
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
esac

bin_dir="$(cd "$(dirname "$0")" && pwd)"
paths=("$("$bin_dir/wiki-root")")
[[ "$include_docs" -eq 1 ]] && paths+=("$("$bin_dir/docs-root")")

out=""

for root in "${paths[@]}"; do
  [[ -d "$root" ]] || continue
  while IFS= read -r -d '' file; do
    file_out="$(awk -v F="$file" '
      BEGIN { in_code = 0 }
      /^[[:space:]]*```/ { in_code = !in_code; next }
      in_code { next }
      {
        s = $0
        # Strip inline-code spans so example links inside backticks are not flagged.
        gsub(/`[^`]*`/, "", s)
        while (match(s, /\[[^]]*\]\([^)]+\)/)) {
          chunk = substr(s, RSTART, RLENGTH)
          s = substr(s, RSTART + RLENGTH)
          sub(/^[^(]*\(/, "", chunk)
          sub(/\)$/, "", chunk)
          sub(/[[:space:]]+\".*$/, "", chunk)
          sub(/#.*$/, "", chunk)
          if (chunk == "") continue
          # False-positive guard: nested parens in link-text (e.g. [Foo (bar)](url))
          # cause the regex to match starting mid-link. Skip if chunk still contains "](".
          if (chunk ~ /\]\(/) continue
          if (chunk ~ /^(https?:|mailto:|tel:|ftp:)/) continue
          if (chunk ~ /^\//) {
            target = chunk
          } else {
            cmd = "dirname \"" F "\""
            cmd | getline dir
            close(cmd)
            target = dir "/" chunk
          }
          cmd = "readlink -m \"" target "\" 2>/dev/null || printf %s \"" target "\""
          cmd | getline resolved
          close(cmd)
          if (system("test -e \"" resolved "\"") != 0) {
            printf "%s:%d:%s\n", F, NR, chunk
          }
        }
      }
    ' "$file")"
    if [[ -n "$file_out" ]]; then
      out+="$file_out"$'\n'
    fi
  done < <(find "$root" -type f -name '*.md' -print0)
done

if [[ -z "$out" ]]; then
  exit 0
fi

printf '%s' "$out"
exit 1
