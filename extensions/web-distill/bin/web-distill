#!/usr/bin/env python3
import sys
import json
import urllib.parse
import urllib.request
import os
from bs4 import BeautifulSoup

BROWSERLESS_URL = "http://localhost:3000/function"
DEFAULT_UA = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
COOKIE_FILE = "/tmp/web_distill_cookies.json"

def get_domain(url):
    parsed = urllib.parse.urlparse(url)
    return parsed.netloc

def load_cookies():
    if os.path.exists(COOKIE_FILE):
        try:
            with open(COOKIE_FILE, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {}

def save_cookies(domain, cookies):
    all_cookies = load_cookies()
    all_cookies[domain] = cookies
    try:
        with open(COOKIE_FILE, "w") as f:
            json.dump(all_cookies, f)
    except Exception:
        pass

def get_cookie_header(url):
    domain = get_domain(url)
    all_cookies = load_cookies()
    if domain in all_cookies:
        cookie_list = all_cookies[domain]
        if cookie_list:
            cookie_strs = [f"{c['name']}={c['value']}" for c in cookie_list]
            return "; ".join(cookie_strs)
    return None

def fetch_rendered_html_browserless(url, timeout=30000):
    sys.stderr.write("[web-distill] Launching Headless Browser (Browserless/Chromium)...\n")
    
    js_code = """
    module.exports = async ({ page, context }) => {
        await page.setUserAgent(context.userAgent);
        await page.goto(context.url, {
            waitUntil: 'networkidle2',
            timeout: context.timeout
        });
        
        if (context.scrollPage) {
            // Infinite Scroll implementation
            await page.evaluate(async () => {
                await new Promise((resolve) => {
                    let totalHeight = 0;
                    let distance = 250;
                    let timer = setInterval(() => {
                        let scrollHeight = document.body.scrollHeight;
                        window.scrollBy(0, distance);
                        totalHeight += distance;
                        if (totalHeight >= scrollHeight || totalHeight > 5000) { // Limit scroll to 5000px to prevent infinite loops
                            clearInterval(timer);
                            resolve();
                        }
                    }, 50);
                });
            });
            // Small wait after scroll for lazy components
            await new Promise(r => setTimeout(r, 1000));
        }
        
        const content = await page.content();
        const cookies = await page.cookies();
        return {
            data: { content, cookies },
            type: 'application/json'
        };
    };
    """
    
    payload = {
        "code": js_code,
        "context": {
            "url": url,
            "userAgent": DEFAULT_UA,
            "timeout": timeout,
            "scrollPage": True
        }
    }
    
    req = urllib.request.Request(
        BROWSERLESS_URL,
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"}
    )
    
    try:
        with urllib.request.urlopen(req, timeout=timeout/1000 + 10) as response:
            res_json = json.loads(response.read().decode("utf-8"))
            html = res_json.get("content", "")
            cookies = res_json.get("cookies", [])
            
            # Save cookies from browser to reuse them in future fast fetches
            if cookies:
                domain = get_domain(url)
                save_cookies(domain, cookies)
                sys.stderr.write(f"[web-distill] Saved {len(cookies)} cookies for domain {domain}.\n")
                
            return html
    except Exception as e:
        sys.stderr.write(f"[web-distill] Error fetching via Browserless: {e}\n")
        sys.exit(1)

def smart_fetch(url):
    domain = get_domain(url)
    sys.stderr.write(f"[web-distill] Starting smart fetch for {url}...\n")
    
    # Inject saved cookies if available to reuse established session
    cookie_header = get_cookie_header(url)
    headers = {"User-Agent": DEFAULT_UA}
    if cookie_header:
        headers["Cookie"] = cookie_header
        sys.stderr.write(f"[web-distill] Injecting saved cookies for domain {domain}...\n")
        
    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=8) as response:
            html = response.read().decode("utf-8", errors="ignore")
            
            soup = BeautifulSoup(html, 'html.parser')
            for el in soup(["script", "style"]):
                el.decompose()
            visible_text = soup.get_text().strip()
            
            lower_html = html.lower()
            
            # Check for bot block
            requires_js = any(indicator in lower_html for indicator in [
                "javascript is required", 
                "enable javascript", 
                "please enable js",
                "security challenge",
                "ddos-guard",
                "checking your browser",
                "__cf_chl_opt"
            ])
            
            # Heuristic for Client-Side JS Apps / SPAs
            is_empty_shell = False
            raw_html_len = len(html)
            visible_text_len = len(visible_text)
            has_scripts = "<script" in lower_html
            
            if has_scripts and visible_text_len < 1000 and raw_html_len > 2500:
                is_empty_shell = True
                sys.stderr.write(f"[web-distill] SPA heuristic hit: low text ({visible_text_len} chars) vs large HTML ({raw_html_len} chars). Switching to browser...\n")
            
            if requires_js or is_empty_shell:
                return fetch_rendered_html_browserless(url)
                
            sys.stderr.write("[web-distill] Fast HTTP fetch successful (No browser session needed).\n")
            return html
            
    except Exception as e:
        sys.stderr.write(f"[web-distill] Fast fetch failed ({e}). Falling back to browser...\n")
        return fetch_rendered_html_browserless(url)

def table_to_markdown(table):
    # Convert HTML tables to Markdown tables
    rows = []
    for tr in table.find_all('tr'):
        cells = []
        for cell in tr.find_all(['th', 'td']):
            cell_text = cell.get_text().strip().replace('\n', ' ').replace('|', '\\|')
            cells.append(cell_text)
        if cells:
            rows.append(cells)
            
    if not rows:
        return ""
        
    md_lines = []
    # Add Header
    md_lines.append("| " + " | ".join(rows[0]) + " |")
    # Add Divider
    md_lines.append("| " + " | ".join(["---"] * len(rows[0])) + " |")
    # Add Rows
    for row in rows[1:]:
        if len(row) < len(rows[0]):
            row += [""] * (len(rows[0]) - len(row))
        elif len(row) > len(rows[0]):
            row = row[:len(rows[0])]
        md_lines.append("| " + " | ".join(row) + " |")
        
    return "\n" + "\n".join(md_lines) + "\n"

def html_to_markdown(html):
    soup = BeautifulSoup(html, 'html.parser')
    
    # Parse and convert all tables before stripping structural elements
    for table in soup.find_all('table'):
        table_md = table_to_markdown(table)
        table.replace_with(table_md)
        
    # Advanced DOM Distillation (Noise Reduction)
    # Remove obvious layouts
    for el in soup(["script", "style", "nav", "footer", "header", "iframe", "form", "svg", "noscript", "aside"]):
        el.decompose()
        
    # Filter high link-density sidebars, directories and lists of menus
    for container in soup.find_all(['div', 'section', 'ul', 'ol']):
        text_len = len(container.get_text().strip())
        if text_len == 0:
            continue
        link_text_len = sum(len(a.get_text().strip()) for a in container.find_all('a'))
        # If more than 65% of text consists of link anchor text AND there are multiple links, prune it!
        if link_text_len / text_len > 0.65 and len(container.find_all('a')) > 1:
            container.decompose()

    # Convert headings
    for h in soup.find_all(['h1', 'h2', 'h3', 'h4', 'h5', 'h6']):
        level = int(h.name[1])
        h.replace_with(f"\n\n{'#' * level} {h.get_text().strip()}\n")
        
    # Convert links
    for a in soup.find_all('a', href=True):
        href = a['href']
        text = a.get_text().strip()
        if text and href.startswith(('http://', 'https://')):
            a.replace_with(f"[{text}]({href})")
        elif text:
            a.replace_with(f" {text} ")
            
    # Convert paragraphs
    for p in soup.find_all('p'):
        p.replace_with(f"\n{p.get_text().strip()}\n")
        
    # Convert lists
    for li in soup.find_all('li'):
        li.replace_with(f"\n* {li.get_text().strip()}")
        
    text = soup.get_text()
    
    # Clean up excess empty lines
    lines = [line.strip() for line in text.split('\n')]
    cleaned_lines = []
    prev_empty = False
    for line in lines:
        if line:
            cleaned_lines.append(line)
            prev_empty = False
        else:
            if not prev_empty:
                cleaned_lines.append('')
                prev_empty = True
                
    return '\n'.join(cleaned_lines).strip()

def search_ddg(query):
    encoded_query = urllib.parse.quote_plus(query)
    url = f"https://html.duckduckgo.com/html/?q={encoded_query}"
    html = fetch_rendered_html_browserless(url)
    soup = BeautifulSoup(html, 'html.parser')
    
    results = []
    for res in soup.select('.result'):
        title_el = res.select_one('.result__title')
        snippet_el = res.select_one('.result__snippet')
        if title_el:
            title = title_el.get_text(strip=True)
            link_el = title_el.find('a')
            if link_el and link_el.get('href'):
                raw_link = link_el['href']
                parsed = urllib.parse.urlparse(raw_link)
                queries = urllib.parse.parse_qs(parsed.query)
                if 'uddg' in queries:
                    actual_url = queries['uddg'][0]
                else:
                    if raw_link.startswith('//'):
                        actual_url = 'https:' + raw_link
                    elif raw_link.startswith('/'):
                        actual_url = 'https://duckduckgo.com' + raw_link
                    else:
                        actual_url = raw_link
            else:
                actual_url = ""
                
            snippet = snippet_el.get_text(strip=True) if snippet_el else ""
            if title:
                results.append(f"### [{title}]({actual_url})\n**URL:** {actual_url}\n{snippet}\n")
                
    if not results:
        return "No results found or rate limit/captcha hit."
        
    return f"# Search Results for: {query}\n\n" + "\n".join(results)

def main():
    if len(sys.argv) < 3:
        print("Usage:")
        print("  web-distill fetch <url>       - Fetch a webpage smartly (fast HTTP, fallback to Chromium JS + Scroll)")
        print("  web-distill search <query>    - Perform a web search including JavaScript and format as Markdown")
        sys.exit(1)
        
    command = sys.argv[1].lower()
    argument = " ".join(sys.argv[2:])
    
    if command == "fetch":
        html = smart_fetch(argument)
        markdown = html_to_markdown(html)
        print(markdown)
    elif command == "search":
        result = search_ddg(argument)
        print(result)
    else:
        print(f"Unknown command: {command}")
        sys.exit(1)

if __name__ == "__main__":
    main()
